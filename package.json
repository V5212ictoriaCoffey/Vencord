{
  "name": "vencord",
  "private": true,
  "version": "1.0.0",
  "description": "The cutest Discord client mod",
  "keywords": [],
  "homepage": "https://github.com/Vendicated/Vencord#readme",
  "bugs": {
    "url": "https://github.com/Vendicated/Vencord/issues"
  },
  "license": "GPL-3.0",
  "author": "Vendicated",
  "main": "dist/patcher.js",
  "scripts": {
    "build": "node scripts/build/build.mjs",
    "buildWeb": "node scripts/build/buildWeb.mjs",
    "inject": "node scripts/runInstaller.mjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint-fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "pnpm lint && pnpm testTsc",
    "testTsc": "tsc --noEmit",
    "watch": "node scripts/build/build.mjs --watch",
    "watchWeb": "node scripts/build/buildWeb.mjs --watch",
    "clean": "rm -rf dist",
    "rebuild": "pnpm clean && pnpm build",
    "dev": "node scripts/build/build.mjs --watch",
    "typecheck": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "@vap/core": "0.0.12",
    "@vap/shiki": "0.10.5"
  },
  "devDependencies": {
    "@types/diff": "^5.0.3",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.15.11",
    "@types/react": "^18.0.35",
    "@types/react-dom": "^18.0.11",
    "@types/yazl": "^2.4.2",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "diff": "^5.1.0",
    "esbuild": "^0.17.17",
    "eslint": "^8.38.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-path-alias": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "highlight.js": "10.7.3",
    "typescript": "^5.0.4",
    "yazl": "^2.5.1"
  },
  "packageManager": "pnpm@8.1.1",
  "pnpm": {
    "patchedDependencies": {}
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
